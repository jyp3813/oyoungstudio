{
  "entities": {
    "PortfolioItem": {
      "title": "Portfolio Item",
      "description": "A video project in the portfolio.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "thumbnail": { "type": "string", "format": "uri" },
        "videoUrl": { "type": "string", "format": "uri" },
        "date": { "type": "string", "format": "date-time" },
        "order": { "type": "number" },
        "titleFontSize": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "thumbnail"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "A message from a potential client.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Setting": {
      "title": "Site Settings",
      "description": "Global configuration for the site.",
      "type": "object",
      "properties": {
        "siteName": { "type": "string" },
        "systemLogo": { "type": "string" },
        "logoType": { "type": "string", "enum": ["text", "image"] },
        "logoUrl": { "type": "string" },
        "heroAccent": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroTitleType": { "type": "string", "enum": ["text", "image"] },
        "heroTitleUrl": { "type": "string" },
        "heroDesc": { "type": "string" },
        "strategyTitle": { "type": "string" },
        "executionTitle": { "type": "string" },
        "purposeTitle": { "type": "string" },
        "purposeDesc": { "type": "string" },
        "ctaTitle": { "type": "string" },
        "featuredCategory": { "type": "string" },
        "featuredTitle": { "type": "string" },
        "featuredImageUrl": { "type": "string" },
        "featuredVideoUrl": { "type": "string" },
        "instagramUrl": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "primaryColor": { "type": "string" },
        "accentColor": { "type": "string" }
      }
    },
    "Admin": {
        "title": "Admin User",
        "description": "A user with administrative privileges.",
        "type": "object",
        "properties": {
            "email": { "type": "string" },
            "role": { "type": "string", "enum": ["admin"] }
        }
    }
  },
  "firestore": {
    "/portfolio/{projectId}": {
      "schema": "PortfolioItem",
      "description": "Portfolio work items."
    },
    "/inquiries/{inquiryId}": {
        "schema": "Inquiry",
        "description": "Contact form submissions."
    },
    "/settings/config": {
      "schema": "Setting",
      "description": "Global site settings."
    },
    "/admins/{userId}": {
        "schema": "Admin",
        "description": "User roles and permissions."
    }
  }
}
