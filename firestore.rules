rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'jyp3813@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Specific Helpers ---
    function isValidPortfolioItem(data) {
      return data.keys().hasAll(['title', 'category', 'thumbnail']) &&
             data.keys().size() <= 12 &&
             data.title is string && data.title.size() <= 100 &&
             data.category is string && data.category.size() <= 50 &&
             data.thumbnail is string && data.thumbnail.size() <= 1000 &&
             (data.get('videoUrl', '') is string) &&
             (data.get('titleFontSize', '') is string) &&
             (data.get('order', 0) is number);
    }

    function isValidSetting(data) {
      return data.keys().size() <= 30 &&
             (data.get('siteName', '') is string && data.get('siteName', '').size() <= 100);
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt']) &&
             data.keys().size() <= 8 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.message is string && data.message.size() <= 5000 &&
             data.createdAt is timestamp;
    }

    // --- Matches ---

    match /admins/{userId} {
      allow get: if isAdmin() && (request.auth.uid == userId || request.auth.token.email == 'jyp3813@gmail.com');
      allow write: if isAdmin() && (request.auth.uid == userId || request.auth.token.email == 'jyp3813@gmail.com');
      allow list: if false; 
    }

    match /settings/config {
      allow get: if true; 
      allow write: if isAdmin() && isValidSetting(incoming());
    }

    match /portfolio/{projectId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin() && isValidPortfolioItem(incoming()) && isValidId(projectId) && 
                      incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidPortfolioItem(incoming()) &&
                      incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
        allow create: if isValidInquiry(incoming()) && 
                        incoming().createdAt == request.time &&
                        isValidId(inquiryId);
        allow read, write: if isAdmin();
    }
  }
}
